# cprr Environment Configuration
# Run `gmake .env` to create .env from this template
# Then uncomment and edit values as needed
# Run `direnv allow` to load changes

# Go binary (override for systems where `go` is not in PATH)
# FreeBSD: GO=go124
# GO=go

# Data store location (optional, overrides default ~/.cprr)
# CPRR_DATA_DIR=/path/to/data

# Feature flags (for future use)
# CPRR_ENABLE_SYNC=false
# CPRR_ENABLE_EXPORT=false

# CI/CD specific
# CPRR_CI=true
# CPRR_NO_COLOR=true
